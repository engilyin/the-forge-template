# FORGE Configuration — Personal/Project Settings
# Copy this file to .forge/config.env and fill in your values.
# .forge/config.env is gitignored — DO NOT commit it.

# ─── Git Author ───────────────────────────────────────
# Used for all commits and PRs created by FORGE automation.
# If not set, falls back to `git config user.name` / `git config user.email`.
FORGE_AUTHOR_NAME="Your Name"
FORGE_AUTHOR_EMAIL="your.email@example.com"

# ─── Branching Strategy ──────────────────────────────
# Base branch for PRs and worktree creation.
# "develop" = Git Flow: AI merges PRs to develop, human releases develop → main.
# "main"    = Trunk-Based: AI merges PRs directly to main.
FORGE_BASE_BRANCH="develop"

# ─── Project Secrets Copy Patterns ────────────────────
# Files to copy from the main project checkout into worktrees.
# These are typically gitignored secrets/config files.
# Comma-separated patterns relative to the project root.
FORGE_SECRET_FILES="src/main/resources/application-default.properties,src/main/resources/application-local.properties,.env,.env.local,.env.development.local"

# ─── Build Commands (override defaults per project) ───
# Java project
# FORGE_BUILD_CMD="./gradlew clean build"
# FORGE_FORMAT_CMD="./gradlew spotlessApply"
# FORGE_CODEGEN_CMD="./gradlew openApiGenerate"

# React/Node project
# FORGE_BUILD_CMD="npm run build"
# FORGE_FORMAT_CMD="npx prettier --write src/"
# FORGE_LINT_CMD="npx eslint src/"
# FORGE_TYPECHECK_CMD="npx tsc --noEmit"
# FORGE_TEST_CMD="npx vitest run"

# ─── Rate Limit Handling ─────────────────────────────
# Delay in seconds between story implementations (reduces rate-limit risk).
# Set higher when multiple agents run in parallel.
FORGE_STORY_DELAY_SECONDS=30

# ─── PR Configuration ────────────────────────────────
# Auto-merge PRs to FORGE_BASE_BRANCH after validation passes.
# Set to "false" to create PRs without auto-merging.
FORGE_AUTO_MERGE_PR="true"
